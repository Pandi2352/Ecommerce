# ── Client (Vite + React) environment ────────────────────────────
# Copy to `frontend/.env` and fill in real values. Never commit `.env`.
# Only variables prefixed with VITE_ are exposed to the browser.

# API base URL (NestJS server)
VITE_API_URL=http://localhost:4000/api

# Realtime WebSocket namespace
VITE_WS_URL=http://localhost:4000/realtime

# App metadata
VITE_APP_NAME=Ecommerce Admin
