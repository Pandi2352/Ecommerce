# ── Server (NestJS API) environment ──────────────────────────────
# Copy to `backend/.env` and fill in real values. Never commit `.env`.

# App
NODE_ENV=development
PORT=4000
API_PREFIX=/api
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174   # CORS: client origin(s), comma-separated

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ecommerce
# Transactions (atomic multi-doc order updates) require a replica set.
# Use a local single-node replica set, or a MongoDB Atlas URI, e.g.:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ecommerce

# Auth / JWT  (use long random strings — generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=7d
# Signs password-reset / email-verification / invite tokens (must differ from access secret)
JWT_MAIL_SECRET=change-me-mail

# Seed super admin — created by `npm run seed --workspace backend`
ADMIN_EMAIL=admin@nova.shop
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Store Admin

# Mail (optional — if SMTP_HOST is empty, invite/reset links are logged to the API console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=NovaShop <no-reply@nova.shop>

# Google OAuth (optional — the strategy only activates when both are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# File uploads / storage (used from Sprint 4+)
UPLOAD_DRIVER=local                      # local | s3
UPLOAD_DIR=./uploads                     # used when UPLOAD_DRIVER=local
# S3-compatible (used when UPLOAD_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
