# ── Storefront (Vite + React) environment ───────────────────────
# Copy to `storefront/.env` and fill in real values. Never commit `.env`.
# Only variables prefixed with VITE_ are exposed to the browser.

# Public API base URL (NestJS server — storefront uses the /storefront/* endpoints)
VITE_API_URL=http://localhost:4000/api

# App metadata
VITE_APP_NAME=NovaShop
